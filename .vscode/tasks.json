{
	"version": "2.0.0",
	"tasks": [
		{
			"label": "Start Backend Server",
			"type": "shell",
			"command": "npm",
			"args": [
				"run",
				"dev"
			],
			"options": {
				"cwd": "${workspaceFolder}/backend"
			},
			"group": "build",
			"isBackground": true,
			"problemMatcher": [],
			"presentation": {
				"echo": true,
				"reveal": "always",
				"focus": false,
				"panel": "shared",
				"showReuseMessage": true,
				"clear": false
			}
		},
		{
			"label": "Start Frontend Server",
			"type": "shell",
			"command": "npm",
			"args": [
				"start"
			],
			"options": {
				"cwd": "${workspaceFolder}/frontend"
			},
			"group": "build",
			"isBackground": true,
			"problemMatcher": [],
			"presentation": {
				"echo": true,
				"reveal": "always",
				"focus": false,
				"panel": "shared",
				"showReuseMessage": true,
				"clear": false
			}
		},
		{
			"label": "Start Development Environment",
			"dependsOrder": "parallel",
			"dependsOn": [
				"Start Backend Server",
				"Start Frontend Server"
			],
			"group": {
				"kind": "build",
				"isDefault": true
			},
			"presentation": {
				"echo": true,
				"reveal": "always",
				"focus": false,
				"panel": "shared",
				"showReuseMessage": true,
				"clear": false
			}
		},
		{
			"label": "Clean and Start Frontend",
			"type": "shell",
			"command": "powershell",
			"args": [
				"-Command",
				"if (Test-Path 'node_modules\\.cache') { Remove-Item -Path 'node_modules\\.cache' -Recurse -Force }; if (Test-Path 'build') { Remove-Item -Path 'build' -Recurse -Force }; npm start"
			],
			"isBackground": true,
			"problemMatcher": [],
			"group": "build"
		},
		{
			"label": "Fresh Frontend Start",
			"type": "shell",
			"command": "powershell",
			"args": [
				"-c",
				"Remove-Item -Path 'node_modules\\.cache' -Recurse -Force -ErrorAction SilentlyContinue; Remove-Item -Path 'build' -Recurse -Force -ErrorAction SilentlyContinue; Set-Content -Path 'refresh.txt' -Value (Get-Date); npm start"
			],
			"isBackground": true,
			"problemMatcher": [],
			"group": "build"
		},
		{
			"label": "Frontend Cache Clear Start",
			"type": "shell",
			"command": "powershell",
			"args": [
				"-c",
				"Remove-Item -Path 'node_modules\\.cache' -Recurse -Force -ErrorAction SilentlyContinue; Remove-Item -Path 'build' -Recurse -Force -ErrorAction SilentlyContinue; npm run start"
			],
			"isBackground": true,
			"problemMatcher": [],
			"group": "build"
		},
		{
			"label": "Serve Production Build",
			"type": "shell",
			"command": "npm",
			"args": [
				"run",
				"serve"
			],
			"options": {
				"cwd": "${workspaceFolder}/frontend"
			},
			"isBackground": true,
			"group": "build"
		},
		{
			"label": "Build Frontend Production",
			"type": "shell",
			"command": "npm",
			"args": [
				"run",
				"build"
			],
			"options": {
				"cwd": "${workspaceFolder}/frontend"
			},
			"isBackground": true,
			"group": "build"
		},
		{
			"label": "React Scripts Build",
			"type": "shell",
			"command": "react-scripts",
			"args": [
				"build"
			],
			"isBackground": true,
			"group": "build"
		},
		{
			"label": "Run Manual Campaign Test",
			"type": "shell",
			"command": "node",
			"args": [
				"direct-test.js"
			],
			"isBackground": false,
			"group": "test"
		},
		{
			"label": "Send Real WhatsApp Messages",
			"type": "shell",
			"command": "node",
			"args": [
				"direct-test.js"
			],
			"isBackground": false,
			"group": "test"
		},
		{
			"label": "Send Fixed Messages",
			"type": "shell",
			"command": "node",
			"args": [
				"send-fixed.js"
			],
			"isBackground": false,
			"group": "test"
		}
	]
}